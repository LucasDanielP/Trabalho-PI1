generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id       String   @id @default(cuid())
  nome     String
  email    String   @unique
  senha    String
  criadoEm DateTime @default(now())

  @@map("usuarios")
}
